# Firebase
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id

# EmailJS
REACT_APP_EMAILJS_SERVICE_ID=your_emailjs_service_id
REACT_APP_EMAILJS_TEMPLATE_REGISTER=your_template_id_for_registration
REACT_APP_EMAILJS_TEMPLATE_TURN=your_template_id_for_turns
REACT_APP_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# Admin
REACT_APP_ADMIN_EMAIL=your_admin_notification_email
REACT_APP_ADMIN_EMAIL_1=first_admin@example.com
REACT_APP_ADMIN_EMAIL_2=second_admin@example.com

# Vaccinators default password (ideally replace with a random generator)
REACT_APP_DEFAULT_VACCINATOR_PASSWORD=change_this_password
